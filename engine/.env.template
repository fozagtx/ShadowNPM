# Engine — Environment Template
# Copy to .env and fill in real values.

# API server
SHADOWNPM_API_HOST=0.0.0.0
SHADOWNPM_API_PORT=8000

# LLM backend: "anthropic" or "openai_compatible"
SHADOWNPM_LLM_BACKEND=openai_compatible
SHADOWNPM_LLM_BASE_URL=https://api.featherless.ai/v1
SHADOWNPM_LLM_API_KEY=

# x402 / Arc Nanopayments
# SHADOWNPM_PAYEE_ADDRESS=0x...       # Your 0x wallet address to receive USDC (uncomment to enable payments)
SHADOWNPM_FACILITATOR_URL=https://x402.org/facilitator
SHADOWNPM_AUDIT_PRICE_USD=$0.001     # Price per audit in USDC

# IPFS publish (Pinata)
PINATA_JWT=
PINATA_GATEWAY_HOST=gateway.pinata.cloud

# ENS publish (Sepolia)
SEPOLIA_RPC_URL=
SEPOLIA_PRIVATE_KEY=
SHADOWNPM_BASE_DOMAIN=shadownpm.eth

# Per-phase models (Featherless AI — OpenAI-compatible)
SHADOWNPM_TRIAGE_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
SHADOWNPM_INVESTIGATION_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
SHADOWNPM_TEST_GEN_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
